CREATE TABLE "Admin" (
    "Id" SERIAL PRIMARY KEY,
    "FirstName" VARCHAR(100) NOT NULL,
    "LastName" VARCHAR(100) NOT NULL,
    "Phone" VARCHAR(15),
    "Email" VARCHAR(150) UNIQUE NOT NULL,
    "PasswordHash" TEXT NOT NULL,
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE sizes (
    id SERIAL PRIMARY KEY,
    size_name VARCHAR(50) NOT NULL,
    description VARCHAR(150),
    is_active BOOLEAN DEFAULT TRUE
);

CREATE TABLE category (
    "Id" SERIAL PRIMARY KEY,
    "Name" VARCHAR(150) NOT NULL,
    "ImageUrl" TEXT, 
    "Status" BOOLEAN DEFAULT TRUE, 
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE subCategory (
    "Id" SERIAL PRIMARY KEY,
    "CategoryId" INT NOT NULL,
    "subCategoryName" VARCHAR(150) NOT NULL,
    "subCategoryImageUrl" TEXT,
    "Status" BOOLEAN DEFAULT TRUE,
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_category
    FOREIGN KEY ("CategoryId") 
    REFERENCES "category"("Id") 
    ON DELETE CASCADE
);

CREATE TABLE childCategory (
    "Id" SERIAL PRIMARY KEY,

    "CategoryId" INT NOT NULL,
    "SubCategoryId" INT NOT NULL,

    "ChildCategoryName" VARCHAR(150) NOT NULL,
    "ChildCategoryImageUrl" TEXT,

    "Status" BOOLEAN DEFAULT TRUE,
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_child_category_category
        FOREIGN KEY ("CategoryId")
        REFERENCES "category"("Id")
        ON DELETE CASCADE,

    CONSTRAINT fk_child_category_subcategory
        FOREIGN KEY ("SubCategoryId")
        REFERENCES "subcategory"("Id")
        ON DELETE CASCADE
);


CREATE TABLE brand (
    id SERIAL PRIMARY KEY,
    brandname VARCHAR(100) NOT NULL,
    brandimage TEXT,
    isactive BOOLEAN DEFAULT TRUE
);


CREATE TABLE color (
    id SERIAL PRIMARY KEY,
    colorname VARCHAR(100) NOT NULL,
    colorcode VARCHAR(20),
    isactive BOOLEAN DEFAULT TRUE
);


CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    firstname VARCHAR(100) NOT NULL,
    lastname VARCHAR(100),
    email VARCHAR(150) UNIQUE NOT NULL,
    password TEXT NOT NULL,
    role VARCHAR(50) DEFAULT 'USER',
    isactive BOOLEAN DEFAULT TRUE,
    createdat TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE contact (
    id SERIAL PRIMARY KEY,
    fullname VARCHAR(150) NOT NULL,
    email VARCHAR(150) NOT NULL,
    phone VARCHAR(20),
    subject VARCHAR(200),
    message TEXT NOT NULL,
    isread BOOLEAN DEFAULT FALSE,
    createdat TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE product (
    id SERIAL PRIMARY KEY,
    productname VARCHAR(200) NOT NULL,
    slug VARCHAR(200) UNIQUE NOT NULL,
    sku VARCHAR(100) UNIQUE NOT NULL,
    shortdescription TEXT,
    description TEXT,
    price DECIMAL(10,2) NOT NULL,
    stock INT DEFAULT 0,

    categoryid INT NOT NULL,
    subcategoryid INT NOT NULL,
    childcategoryid INT NOT NULL,
    brandid INT,

    sizeids INT[],
    colorids INT[],
    image TEXT,
    imagegallery TEXT[],

    isactive BOOLEAN DEFAULT TRUE,
    createdat TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_product_category
        FOREIGN KEY (categoryid)
        REFERENCES category("Id")
        ON DELETE CASCADE,

    CONSTRAINT fk_product_subcategory
        FOREIGN KEY (subcategoryid)
        REFERENCES subcategory("Id")
        ON DELETE CASCADE,

    CONSTRAINT fk_product_childcategory
        FOREIGN KEY (childcategoryid)
        REFERENCES childcategory("Id")
        ON DELETE CASCADE,

    CONSTRAINT fk_product_brand
        FOREIGN KEY (brandid)
        REFERENCES brand(id)
        ON DELETE SET NULL
    
);


CREATE TABLE variant (
    id SERIAL PRIMARY KEY,
    variantname VARCHAR(200) NOT NULL,

    productid INT NOT NULL,
    sizeid INT[],
    colorid INT[],

    price DECIMAL(10,2) NOT NULL,
    stock INT DEFAULT 0,

    sku VARCHAR(100),


    image TEXT,          -- main image
    imagegallery TEXT[], -- gallery images

    isactive BOOLEAN DEFAULT TRUE,
    createdat TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_variant_product
        FOREIGN KEY (productid)
        REFERENCES product(id)
        ON DELETE CASCADE,

    CONSTRAINT fk_variant_size
        FOREIGN KEY (sizeid)
        REFERENCES sizes(id),

    CONSTRAINT fk_variant_color
        FOREIGN KEY (colorid)
        REFERENCES color(id),

    CONSTRAINT unique_variant UNIQUE (productid, sizeid, colorid)
);


