CREATE TABLE "Admin" (
    "Id" SERIAL PRIMARY KEY,
    "FirstName" VARCHAR(100) NOT NULL,
    "LastName" VARCHAR(100) NOT NULL,
    "Phone" VARCHAR(15),
    "Email" VARCHAR(150) UNIQUE NOT NULL,
    "PasswordHash" TEXT NOT NULL,
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);


CREATE TABLE sizes (
    id SERIAL PRIMARY KEY,
    size_name VARCHAR(50) NOT NULL,
    description VARCHAR(150),
    is_active BOOLEAN DEFAULT TRUE
);

CREATE TABLE category (
    "Id" SERIAL PRIMARY KEY,
    "Name" VARCHAR(150) NOT NULL,
    "ImageUrl" TEXT, 
    "Status" BOOLEAN DEFAULT TRUE, 
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

CREATE TABLE subCategory (
    "Id" SERIAL PRIMARY KEY,
    "CategoryId" INT NOT NULL,
    "subCategoryName" VARCHAR(150) NOT NULL,
    "subCategoryImageUrl" TEXT,
    "Status" BOOLEAN DEFAULT TRUE,
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_category
    FOREIGN KEY ("CategoryId") 
    REFERENCES "category"("Id") 
    ON DELETE CASCADE
);

CREATE TABLE childCategory (
    "Id" SERIAL PRIMARY KEY,

    "CategoryId" INT NOT NULL,
    "SubCategoryId" INT NOT NULL,

    "ChildCategoryName" VARCHAR(150) NOT NULL,
    "ChildCategoryImageUrl" TEXT,

    "Status" BOOLEAN DEFAULT TRUE,
    "CreatedAt" TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT fk_child_category_category
        FOREIGN KEY ("CategoryId")
        REFERENCES "category"("Id")
        ON DELETE CASCADE,

    CONSTRAINT fk_child_category_subcategory
        FOREIGN KEY ("SubCategoryId")
        REFERENCES "subcategory"("Id")
        ON DELETE CASCADE
);


CREATE TABLE brand (
    id SERIAL PRIMARY KEY,
    brandname VARCHAR(100) NOT NULL,
    brandimage TEXT,
    isactive BOOLEAN DEFAULT TRUE
);


CREATE TABLE color (
    id SERIAL PRIMARY KEY,
    colorname VARCHAR(100) NOT NULL,
    colorcode VARCHAR(20),
    isactive BOOLEAN DEFAULT TRUE
);


CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    firstname VARCHAR(100) NOT NULL,
    lastname VARCHAR(100),
    email VARCHAR(150) UNIQUE NOT NULL,
    password TEXT NOT NULL,
    role VARCHAR(50) DEFAULT 'USER',
    isactive BOOLEAN DEFAULT TRUE,
    createdat TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);